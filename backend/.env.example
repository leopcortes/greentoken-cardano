# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/greentoken_db

# Cardano Node
CARDANO_NODE_SOCKET_PATH=/path/to/node.socket
CARDANO_NODE_MAGIC=2

# Raiz do projeto
PROJECT_ROOT=/path/to/greentoken-cardano

# Servidor
PORT=3000

# Polling de confirmação (ms)
CONFIRMATION_POLL_MS=5000

# Greenwallet - Blockfrost (Preprod testnet). Obtenha em https://blockfrost.io
# O prefixo da key define a rede (preprod*, preview*, mainnet*).
BLOCKFROST_API_KEY=preprodXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Greenwallet - chave-mestre AES-256 (32 bytes em base64) para criptografar
# as mnemonicas dos usuarios no Postgres.
# Gere com: openssl rand -base64 32
WALLET_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES

# Autenticacao - senha do owner (acesso a /dashboard)
OWNER_PASSWORD=CHANGE_ME

# Autenticacao - chave HS256 para assinar JWTs
# Gere com: openssl rand -base64 32
AUTH_JWT_SECRET=CHANGE_ME_BASE64_32_BYTES

# TTL dos tokens (opcionais; defaults: 8h para owner, 15min para reciclador)
OWNER_TOKEN_TTL_HOURS=8
RECYCLER_TOKEN_TTL_MIN=15
